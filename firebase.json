{
  "database": {
    "rules": "database.rules.json"
  },
  "functions": {
    "source": "functions",
    "ignore": ["node_modules", ".git", "*.log"]
  },
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [{ "source": "**", "destination": "/index.html" }]
  }
}
